# LiveKit
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# Auth — Firebase (production) or Supabase (legacy dev)
AUTH_PROVIDER=firebase
FIREBASE_CREDENTIALS_JSON=  # Path to service account JSON or JSON string
# Legacy Supabase (set AUTH_PROVIDER=supabase to use)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters

# Database
# SQLite (dev):  sqlite+aiosqlite:///./data/kodama.db
# PostgreSQL:    postgresql+asyncpg://user:pass@host/dbname
DATABASE_URL=sqlite+aiosqlite:///./data/kodama.db

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# AIHubMix - Unified API Gateway (https://console.aihubmix.com)
AIHUBMIX_API_KEY=sk-***
AIHUBMIX_BASE_URL=https://aihubmix.com/v1

# DashScope - Alibaba Cloud (ASR + CosyVoice TTS)
DASHSCOPE_API_KEY=
DASHSCOPE_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/inference

# App
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000
